# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.spec.bak

# Виртуальные окружения
.venv/
venv/
env/

# Логи и временные файлы
*.log
logs/
*.tmp

# IDE
.vscode/
.idea/

# Сборка артефактов (собираются в CI, не храним в репо)
*.exe

# Установленные агентские скиллы — инструменты разработки, не часть продукта.
# Доступны локально (симлинки в .claude/skills), но не храним в репозитории.
/.agents/
/.claude/skills/*
!/.claude/skills/find-skills/
skills-lock.json
